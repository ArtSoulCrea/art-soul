---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Art Soul — Justine',
  description = 'Justine transforme les failles en lumière — peinture et dessin.',
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<script>
  // Scroll fluide sans modifier l'URL — remplace tous les href="#id"
  document.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest<HTMLElement>("[data-scroll-to]");
    if (!btn) return;
    const target = document.getElementById(btn.dataset.scrollTo!);
    target?.scrollIntoView({ behavior: "smooth" });
  });
</script>
