---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import defaultOgImage from "../assets/og/ogimage.png";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Art Soul — Justine",
  description = "Je m'appele Justine et je suis artiste émotionnelle. Je réalise des oeuvres qui raconte une histoire. Deuil, renaissance, parcours de vie, hommage ou transformation, je mets en valeur vos émotions pour en faire une force. Vous me racontez votre histoire, et je la transforme en une oeuvre unique qui vous accompagnera. J'utilise principalement la peinture et le dessin pour la réalisation de mes créations.",
  ogImage = defaultOgImage.src,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin)
  .href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Art Soul" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  // Scroll fluide sans modifier l'URL — remplace tous les href="#id"
  document.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest<HTMLElement>("[data-scroll-to]");
    if (!btn) return;
    const target = document.getElementById(btn.dataset.scrollTo!);
    target?.scrollIntoView({ behavior: "smooth" });
  });
</script>
