---
// Section About — grande photo gauche, texte + petite photo droite
import { Image } from "astro:assets";
import justineImg from "../../assets/others/justine.webp";
---

<!-- ============================================================
     SECTION ABOUT
     ============================================================ -->
<section id="about" class="bg-paper py-24 px-6 lg:px-0 overflow-hidden">
  <div
    class="max-w-6xl mx-auto lg:grid lg:grid-cols-[3fr_2fr] lg:min-h-screen lg:items-center"
  >
    <!-- ── Colonne gauche : grande photo ──────────────────────────────── -->
    <div class="relative mb-12 lg:mb-0">
      <div class="lg:h-screen" aria-label="Photo de Justine">
        <Image
          src={justineImg}
          alt="Photo de Justine"
          class="w-full h-full object-cover pointer-events-none select-none"
          draggable="false"
          loading="lazy"
        />
      </div>
    </div>

    <!-- ── Colonne droite : texte + petite photo ──────────────────────── -->
    <div class="lg:py-32 lg:px-12 flex flex-col justify-center gap-12">
      <!-- En-tête -->
      <div id="about-header">
        <p class="font-sans text-xs tracking-[0.3em] text-gold uppercase mb-6">
          À propos
        </p>
        <h2
          class="font-display text-5xl lg:text-6xl text-ink leading-tight mb-8"
        >
          Justine
        </h2>
        <div class="w-16 h-px bg-gold/50"></div>
      </div>

      <!-- Texte biographique -->
      <div
        id="about-bio"
        class="space-y-4 font-serif text-ink/75 text-lg lg:text-xl
      leading-relaxed"
      >
        <p>
          Moi c’est Justine. Maman de deux merveilleux petits chaos • ma koala
          et mon chaton • et artiste derrière ArtSoul.
        </p>

        <p>
          ArtSoul est né après une hospitalisation fin 2021. À ce moment-là, le
          dessin est devenu ma bouée. Ma façon de respirer, de transformer ce
          que je ressentais en quelque chose de vivant.
        </p>

        <p>
          Puis j’ai compris que je ne dessinais pas seulement.<br />
          Je racontais des histoires.<br />
          Des émotions.<br />
          Des fragments de vie.
        </p>

        <p>
          Aujourd’hui, ArtSoul est devenu un univers où les émotions et les
          histoires deviennent des œuvres.
        </p>
        <p>
          Quand je ne dessine pas, j’aime observer, écouter, imaginer… et
          probablement boire un coca pendant que le chaos familial s’organise
          autour de moi 🤣🖤
        </p>
      </div>
    </div>
  </div>

  <script>
    import { gsap, ScrollTrigger } from "../../lib/gsap";

    document
      .querySelector('[aria-label="Photo de Justine"]')
      ?.addEventListener("contextmenu", (e) => e.preventDefault());

    const tl = gsap.timeline({
      scrollTrigger: { trigger: "#about", start: "top 60%" },
    });

    tl.from("#about-photo-main", {
      x: -40,
      autoAlpha: 0,
      duration: 0.9,
      ease: "power2.out",
    })
      .from(
        "#about-header",
        { y: 25, autoAlpha: 0, duration: 0.7, ease: "power2.out" },
        "-=0.5",
      )
      .from(
        "#about-bio p",
        {
          y: 15,
          autoAlpha: 0,
          duration: 0.6,
          ease: "power2.out",
          stagger: 0.15,
        },
        "-=0.3",
      );
  </script>
</section>
