---
// Section Commandes émotionnelles — texte, process, CTA contact
---

<!-- ============================================================
     SECTION COMMANDES ÉMOTIONNELLES
     ============================================================ -->
<section id="commandes" class="bg-paper py-24 lg:py-32 px-6">
  <div class="max-w-2xl mx-auto">
    <!-- En-tête -->
    <div id="commandes-header" class="mb-16">
      <p class="font-sans text-xs tracking-[0.3em] text-gold uppercase mb-6">
        Commandes émotionnelles
      </p>
      <h2 class="font-display text-5xl lg:text-6xl text-ink leading-tight mb-8">
        Et si votre propre histoire devenait une œuvre&nbsp;?
      </h2>
      <div class="w-16 h-px bg-gold/50"></div>
    </div>

    <!-- Introduction -->
    <div id="commandes-intro" class="mb-16 space-y-6">
      <p class="font-serif text-ink/75 text-2xl leading-relaxed text-center">
        Je crée l'<span class="font-semibold text-gold/80">œuvre unique</span>,
        qui fait écho à votre histoire.
      </p>
      <p class="font-serif italic text-ink/50 text-xl leading-relaxed">
        Hommage, passion, reconstruction... je vous aide à sublimer cette
        émotion pour qu'elle devienne une force.
      </p>
    </div>

    <!-- Process -->
    <div id="commandes-process" class="mb-16 space-y-10 relative py-8">
      <!-- Logo flouté en arrière-plan -->
      <img
        src="/assets/sceau.webp"
        alt="Image sceau ArtSoul"
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-contain opacity-30 pointer-events-none select-none"
      />

      <!-- Étape 1 -->
      <div class="flex gap-8 items-start relative">
        <span class="font-display text-4xl text-gold/30 leading-none shrink-0"
          >01</span
        >
        <div>
          <h3
            class="font-sans text-xs tracking-[0.2em] uppercase text-ink/50 mb-3"
          >
            Titre étape 1
          </h3>
          <p class="font-serif text-ink text-lg leading-relaxed">
            Description de la première étape du process — ex : le dialogue
            initial, comprendre votre histoire.
          </p>
        </div>
      </div>

      <!-- Étape 2 -->
      <div class="flex gap-8 items-start relative">
        <span class="font-display text-4xl text-gold/30 leading-none shrink-0"
          >02</span
        >
        <div>
          <h3
            class="font-sans text-xs tracking-[0.2em] uppercase text-ink/50 mb-3"
          >
            Titre étape 2
          </h3>
          <p class="font-serif text-ink text-lg leading-relaxed">
            Description de la deuxième étape — ex : la création, les
            allers-retours si besoin.
          </p>
        </div>
      </div>

      <!-- Étape 3 -->
      <div class="flex gap-8 items-start relative">
        <span class="font-display text-4xl text-gold/30 leading-none shrink-0"
          >03</span
        >
        <div>
          <h3
            class="font-sans text-xs tracking-[0.2em] uppercase text-ink/50 mb-3"
          >
            Titre étape 3
          </h3>
          <p class="font-serif text-ink text-lg leading-relaxed">
            Description de la troisième étape — ex : la livraison,
            l'accompagnement, ce que l'œuvre représente une fois terminée.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <button
      id="commandes-cta"
      data-scroll-to="contact"
      class="font-sans text-xs tracking-[0.25em] uppercase font-semibold px-10 py-4 rounded bg-ink text-paper hover:bg-ink/80 transition-colors duration-300 cursor-pointer border-none mx-auto block"
    >
      Partagez votre histoire
    </button>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../../lib/gsap";

  const tl = gsap.timeline({
    scrollTrigger: { trigger: "#commandes", start: "top 70%" },
  });

  tl.from("#commandes-header h2", {
    y: 30,
    autoAlpha: 0,
    duration: 0.7,
    ease: "power2.out",
  })
    .from(
      "#commandes-intro p",
      { y: 15, autoAlpha: 0, duration: 0.5, ease: "power2.out", stagger: 0.15 },
      "-=0.3",
    )
    .from(
      "#commandes-process .flex",
      { y: 20, autoAlpha: 0, duration: 0.5, ease: "power2.out", stagger: 0.15 },
      "-=0.2",
    )
    .from(
      "#commandes-cta",
      { autoAlpha: 0, duration: 0.5, ease: "power2.out" },
      "-=0.1",
    );
</script>
