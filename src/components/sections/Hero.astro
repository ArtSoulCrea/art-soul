---
const oeuvreHero = "/assets/hero-oeuvre.webp"; // remplacer par le vrai fichier
import Fissure from "../Fissure.astro";
import fissureSvg from "../../assets/fissure.svg?raw";
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col overflow-hidden lg:flex-row"
>
  <!-- Image en arrière-plan : mobile uniquement, masquée sur desktop -->
  <div class="absolute inset-0 lg:hidden overflow-hidden">
    <img
      id="hero-bg-img"
      src={oeuvreHero}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover object-center"
    />
    <div
      class="absolute inset-0 bg-linear-to-b from-ink/85 via-ink/72 to-ink/95"
    >
    </div>
  </div>

  <!-- Texte -->
  <div
    class="relative z-10 flex-1 flex flex-col justify-center items-center lg:items-start px-8 md:px-14 lg:px-20 xl:px-28 py-24 lg:py-0"
  >
    <span
      id="hero-prenom"
      class="font-sans text-paper/40 text-xs tracking-[0.4em] uppercase mb-6"
    >
      Justine
    </span>

    <h1 id="hero-title" class="font-display font-bold leading-[0.9] mb-5">
      <span
        class="block text-[clamp(3rem,12vw,6rem)] bg-gradient-to-r from-gold to-paper bg-clip-text text-transparent"
      >
        ARTSOUL
      </span>
    </h1>
    <Fissure rawSvg={fissureSvg} class="w-48 lg:w-64 opacity-60" />

    <!-- Ligne séparatrice animée -->
    <div id="hero-line" class="w-24 h-px bg-violet mb-10"></div>

    <p
      id="hero-tagline"
      class="font-serif italic text-paper/70 text-xl lg:text-2xl mb-14 max-w-sm leading-relaxed"
    >
      Je transforme les failles en lumière
    </p>

    <div id="hero-ctas" class="flex flex-col sm:flex-row gap-4">
      <button
        data-scroll-to="contact"
        class="font-sans text-xs tracking-[0.25em] uppercase rounded font-semibold px-8 py-4 bg-gold text-ink hover:bg-gold/85 hover:text-paper transition-colors duration-300 text-center bg-gold border-none cursor-pointer"
      >
        Commander une création
      </button>
      <button
        data-scroll-to="oeuvres"
        class="font-sans text-xs tracking-[0.25em] uppercase rounded font-medium px-8 py-4 border border-violet text-violet hover:bg-violet hover:text-paper transition-colors duration-300 text-center bg-transparent cursor-pointer"
      >
        Découvrir mes œuvres
      </button>
    </div>
  </div>

  <!-- Image panel : desktop uniquement -->
  <div
    id="hero-image-panel"
    class="hidden lg:flex lg:w-[45%] shrink-0 items-center justify-center"
  >
    <img
      src={oeuvreHero}
      alt="Œuvre de Justine"
      class="h-full max-h-screen w-full object-cover"
    />
  </div>
</section>

<style>
  /*
    Seuls les éléments secondaires sont cachés via CSS.
    #hero-title et #hero-prenom sont laissés visibles pour ne pas pénaliser le LCP Lighthouse.
    Le micro-flash sur le titre est acceptable ; celui sur les CTAs/tagline ne l'est pas.
  */
  #hero-tagline,
  #hero-ctas,
  #hero-image-panel {
    opacity: 0;
  }
  #hero-line {
    transform: scaleX(0);
    transform-origin: center;
  }
</style>

<script>
  import { gsap } from "gsap";

  /*
    On passe de gsap.from() à gsap.set() + gsap.to() :
    - gsap.set() établit l'état de départ (y offset) dès le chargement du script
    - gsap.to() anime vers l'état final explicite (y:0, autoAlpha:1)
    Les éléments étant déjà cachés via CSS, il n'y a aucun flash.
  */

  gsap.set("#hero-tagline", { y: 20 });

  const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

  tl.to("#hero-line", { scaleX: 1, duration: 0.6, ease: "power3.inOut" })
    .to("#hero-tagline", { y: 0, autoAlpha: 1, duration: 0.6 }, "-=0.3")
    .to("#hero-ctas", { autoAlpha: 1, duration: 1 }, "-=0.25");

  const mm = gsap.matchMedia();

  // Desktop : panneau image — déjà opacity:0 via CSS, on set le x puis on anime
  mm.add("(min-width: 1024px)", () => {
    gsap.set("#hero-image-panel", { x: 60 });
    gsap.to("#hero-image-panel", {
      x: 0,
      autoAlpha: 1,
      duration: 1.1,
      ease: "power3.out",
      delay: 0.3,
    });
  });

  // Mobile : zoom arrière sur l'image de fond (reste toujours visible, pas de opacity)
  mm.add("(max-width: 1023px)", () => {
    gsap.from("#hero-bg-img", {
      scale: 1.3,
      duration: 2.5,
      ease: "power2.out",
    });
  });
</script>
