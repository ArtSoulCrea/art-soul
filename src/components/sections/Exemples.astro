---
import { Image } from "astro:assets";
import img1 from "../../assets/creations/image1.webp";
import img2 from "../../assets/creations/image2.webp";
import img3 from "../../assets/creations/image3.webp";
import img4 from "../../assets/creations/image4.webp";
import img5 from "../../assets/creations/image5.webp";
import img6 from "../../assets/creations/image6.webp";
import img7 from "../../assets/creations/image7.webp";

const exemples = [
  {
    id: "ex-1",
    image: img1,
    titre: " Une présence pour toujours",
    description:
      "Commande émotionnelle — Dessin tatouage pour une mamange\n" +
      "Cette création est née d’une histoire profondément intime.\n" +
      "Une mamange souhaitait porter son bébé avec elle.\n" +
      "Pas seulement dans son cœur.\n" +
      "Sur sa peau.\n" +
      "Parce qu’il existe des douleurs pour lesquelles il n’y a pas vraiment de mots.\n" +
      "Perdre son bébé fait partie de celles-là.\n" +
      "Le dessin a été imaginé comme un lien.\n" +
      "Une présence.\n" +
      "Une façon de dire :\n" +
      "Tu existes.\n" +
      "Certaines œuvres ne sont pas faites pour être accrochées.\n" +
      "Elles deviennent tatouage.\n" +
      "Mémoire.\n" +
      "Amour.\n" +
      "Parce que certaines histoires ne quittent jamais vraiment ceux qui les portent",
  },
  {
    id: "ex-2",
    image: img2,
    titre: " La Fresque du Dojo — Quand une rencontre devient un projet",
    description:
      "Cette création est née d’une rencontre lors d’un marché.\n" +
      "Parmi les visiteurs se trouvait un couple.\n" +
      "Il s’arrête et me commande une pièce.\n" +
      "Je la livre au dojo pendant que leur fille fait du judo.\n" +
      "Le sensei découvre mon art.\n" +
      "Quelques temps plus tard, il me recontacte.\n" +
      "L’idée était ambitieuse :\n" +
      "Créer une fresque inspirée de l’univers japonais et du judo.\n" +
      "Une œuvre pensée pour habiter le dojo.\n" +
      "Pour transmettre des valeurs.\n" +
      "Le respect.\n" +
      "La discipline.\n" +
      "La force. \n" +
      "Le projet a été imaginé dans une palette noir, blanc et bordeaux pour conserver l’élégance, la sobriété et l’esprit japonais.\n" +
      "Cette œuvre marque une étape particulière dans mon parcours.\n" +
      "Parce qu’elle est née d’un simple échange…\n" +
      "et qu’elle est devenue une création à grande échelle.",
  },
  {
    id: "ex-3",
    image: img3,
    titre: "Trois compagnons — Réunis dans une même œuvre",
    description:
      "Cette création est née d’une demande simple.\n" +
      "Réunir trois compagnons de vie sur une seule œuvre.\n" +
      "Trois présences.\n" +
      "Trois histoires.\n" +
      "Trois fragments d’une même vie.\n" +
      "La commande a été réalisée en line art pour garder la douceur, la simplicité et laisser toute la place au lien qui les unit.\n" +
      "Parfois il ne s’agit pas de raconter une absence.\n" +
      "Ni une blessure.\n" +
      "Parfois il s’agit simplement de célébrer ceux qui partagent notre quotidien.\n" +
      "Et de leur offrir une place à travers l’art.",
  },
  {
    id: "ex-4",
    image: img4,
    titre: "Fabio & Xena — Quand l’amour continue d’exister",
    description:
      "Cette œuvre est née pendant l’été 2022.\n" +

      "J’ai été contactée pendant mes vacances par une personne qui souhaitait offrir quelque chose de particulier à son amie.\n" +
      "Elle venait de perdre Fabio et Xena.\n" +
      "Deux compagnons.\n" +
      "Deux présences.\n" +
      "Deux fragments de vie.\n" +
      "L’objectif n’était pas seulement d’offrir un tableau.\n" +
      "Il fallait créer un espace.\n" +
      "Un souvenir.\n" +
      "Une présence qui continuerait d’exister autrement.\n" +
      "J’ai accepté cette commande sans hésiter.\n" +
      "Et je ne l’ai jamais regretté.\n" +
      "Parce que certaines œuvres dépassent le dessin.\n" +
      "Elles deviennent un morceau d’histoire.\n" +
      "Aujourd’hui encore, cette création est tellement chargée d’émotions que sa propriétaire a du mal à l’afficher.\n" +
      "Pas parce qu’elle ne l’aime pas.\n" +
      "Mais parce qu’elle ressent tout ce qu’elle porte.",
  },
  {
    id: "ex-5",
    image: img5,
    titre: "Le chant des profondeurs",
    description:
      "Cette œuvre a été créée pour accompagner une femme dans sa sortie de burn-out.\n" +

      "La baleine s’est imposée naturellement.\n" +

      "Animal de profondeur.\n" +

      "De mémoire.\n" +

      "De voyage.\n" +

      "Elle symbolise ces périodes où l’on plonge loin.\n" +

      "Très loin.\n" +

      "Parfois trop loin.\n" +

      "Puis le moment où l’on remonte.\n" +

      "Où l’on réapprend à respirer.\n" +

      "Ses couleurs racontent le mouvement.\n" +

      "La vie qui revient.\n" +

      "Les émotions qui circulent à nouveau.\n" + 

      "Les touches dorées rappellent cette idée qui deviendra plus tard l’essence d’ArtSoul :\n" +

      "Même au milieu des tempêtes…\n" +

      "quelque chose peut encore briller.\n" +

      "Une œuvre sur la reconstruction, la résilience et le retour à soi.",
  },
  {
    id: "ex-6",
    image: img6,
    titre: "Olaf — Une histoire portée à jamais",
    description:
      "Cette œuvre est née après la perte d’Olaf.\n" +
      "Une disparition brutale.\n" +
      "Une maladie fulgurante.\n" +
      "Une histoire qui a laissé un vide immense.\n" +
      "Sa propriétaire m’a confié son histoire.\n" +
      "J’ai réalisé son portrait pour transformer ce souvenir en quelque chose qui puisse continuer à exister.\n" +
      "Mais cette création a pris une autre dimension.\n" +
      "Elle a choisi de la porter sur elle.\n" +
      "Pour toujours.\n" +
      "Le dessin est devenu tatouage.\n" +
      "Un hommage.\n" +
      "Une présence.\n" +
      "Un lien qui ne disparaît pas.\n" +
      "Parce que certaines histoires ne s’effacent jamais.\n" +
      "Elles changent simplement de forme.",

  },
  {
    id: "ex-7",
    image: img7,
    titre: "Les ailes invisibles",
    description: "Cette œuvre est née pour une femme dont le parcours est marqué par le handicap.\n" +

"L’abeille est devenue son symbole.\n" +

"Celui de la persévérance.\n" +

"Du courage discret.\n" +

"De cette force que l’on ne voit pas toujours.\n" +

"L’or vient souligner ce qui reste invisible aux yeux des autres :\n" +

"Le combat.\n" +

"L’adaptation.\n" +

"La résilience.\n" +  

"Parce que certaines personnes portent des ailes que le monde ne voit pas.",
     
  },
];
---

<!-- ============================================================
     SECTION EXEMPLES DE RÉALISATIONS
     ============================================================ -->
<section id="exemples" class="bg-ink py-24 overflow-hidden">
  <!-- En-tête -->
  <div class="px-6 lg:px-16 max-w-6xl mx-auto mb-16">
    <p class="font-sans text-xs tracking-[0.3em] text-gold uppercase mb-4">
      Commandes émotionnelles
    </p>
    <h2 class="font-display text-5xl lg:text-6xl text-paper">
      Quelques réalisations
    </h2>
    <div class="w-16 h-px bg-violet mt-6"></div>
  </div>

  <!-- Indice tactile — mobile uniquement -->
  <p class="lg:hidden font-sans text-xs text-paper/30 text-center mb-8 tracking-wide px-6">
    Cliquez sur une réalisation pour la révéler
  </p>

  <!-- Carousel wrapper -->
  <div class="relative">
    <!-- Track scrollable -->
    <div
      id="exemples-track"
      class="flex gap-5 overflow-x-auto scroll-smooth pl-6 lg:pl-16 pr-6 lg:pr-16 pb-2"
    >
      {
        exemples.map((ex) => (
          <div class="shrink-0 w-[80vw] sm:w-[55vw] lg:w-[32%]">
            <button
              type="button"
              data-exemple-id={ex.id}
              data-titre={ex.titre}
              data-description={ex.description}
              data-image={ex.image.src}
              aria-label={`Voir la réalisation : ${ex.titre}`}
              class="group relative w-full aspect-3/4 overflow-hidden cursor-pointer block focus-visible:ring-2 focus-visible:ring-violet focus-visible:ring-offset-2 focus-visible:ring-offset-ink"
            >
              <Image
                src={ex.image}
                alt=""
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none"
                draggable="false"
              />

              <!-- Hover : ombre dégradée + titre + description -->
              <div class="absolute inset-0 bg-linear-to-t from-ink via-ink/60 to-transparent opacity-0 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 flex flex-col justify-end p-4 lg:p-5">
                <p class="font-sans text-xs tracking-[0.2em] text-gold uppercase mb-1">
                  {ex.titre}
                </p>
                <p class="font-serif italic text-paper/80 text-sm leading-relaxed line-clamp-2">
                  {ex.description}
                </p>
              </div>
            </button>
          </div>
        ))
      }

      <!-- Spacer final -->
      <div class="shrink-0 w-6 lg:w-16" aria-hidden="true"></div>
    </div>

    <!-- Flèches desktop -->
    <button
      id="exemples-prev"
      aria-label="Précédent"
      class="hidden lg:flex absolute left-4 top-[40%] -translate-y-1/2 w-10 h-10 items-center justify-center text-paper/40 hover:text-paper transition-colors duration-300 bg-ink/80 rounded-full"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M12 4L6 10L12 16"/>
      </svg>
    </button>

    <button
      id="exemples-next"
      aria-label="Suivant"
      class="hidden lg:flex absolute right-4 top-[40%] -translate-y-1/2 w-10 h-10 items-center justify-center text-paper/40 hover:text-paper transition-colors duration-300 bg-ink/80 rounded-full"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M8 4L14 10L8 16"/>
      </svg>
    </button>
  </div>
</section>

<style>
  #exemples-track {
    scrollbar-width: none;
  }
  #exemples-track::-webkit-scrollbar {
    display: none;
  }
</style>

<!-- ============================================================
     MODAL EXEMPLE
     ============================================================ -->
<div
  id="exemple-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="exemple-modal-titre"
  class="fixed inset-0 z-50 bg-ink/95 hidden overflow-y-auto"
>
  <button
    id="exemple-modal-close"
    type="button"
    aria-label="Fermer"
    class="fixed top-6 right-6 z-10 w-10 h-10 flex items-center justify-center text-paper/50 hover:text-paper transition-colors cursor-pointer"
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path d="M4 4L16 16M16 4L4 16"></path>
    </svg>
  </button>

  <div class="min-h-screen flex flex-col lg:flex-row">
    <!-- Image -->
    <div
      class="lg:w-[58%] flex items-center justify-center p-8 lg:p-16 pt-16 lg:pt-8"
    >
      <img
        id="exemple-modal-image"
        src=""
        alt=""
        draggable="false"
        class="w-full h-[45vh] lg:h-[80vh] object-contain pointer-events-none select-none transition-opacity duration-300"
      />
    </div>

    <!-- Titre + description -->
    <div
      class="lg:w-[42%] flex flex-col justify-center px-8 pb-16 lg:py-16 lg:pr-16"
    >
      <h2
        id="exemple-modal-titre"
        class="font-display text-4xl lg:text-5xl text-paper mb-8"
      ></h2>
      <p
        id="exemple-modal-description"
        class="font-serif text-xl text-paper/75 leading-relaxed whitespace-pre-line"
      ></p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("exemple-modal");
  const closeBtn = document.getElementById("exemple-modal-close");
  let triggerBtn: HTMLElement | null = null;

  function openModal(btn: HTMLElement | null) {
    if (!btn || !modal) return;
    const img = document.getElementById(
      "exemple-modal-image",
    ) as HTMLImageElement;
    const titre = document.getElementById("exemple-modal-titre");
    const desc = document.getElementById("exemple-modal-description");

    if (titre) titre.textContent = btn.dataset.titre ?? "";
    if (desc) desc.textContent = btn.dataset.description ?? "";

    if (btn.dataset.image) {
      img.style.opacity = "0";
      img.src = btn.dataset.image;
      img.alt = btn.dataset.titre || btn.dataset.exempleId?.replace("ex-", "exemple-") || "";
      img.onload = () => {
        img.style.opacity = "1";
      };
      img.style.display = "";
    } else {
      img.style.display = "none";
    }

    triggerBtn = btn;
    modal.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    closeBtn?.focus();
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add("hidden");
    document.body.style.overflow = "";
    triggerBtn?.focus();
  }

  document.querySelectorAll("[data-exemple-id]").forEach((btn) => {
    btn.addEventListener("click", () => openModal(btn as HTMLElement));
  });

  closeBtn?.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.classList.contains("hidden"))
      closeModal();
  });

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  // Blocage clic droit sur toute la section et la modal
  document.addEventListener("contextmenu", (e) => {
    if ((e.target as Element).closest("#exemples, #exemple-modal"))
      e.preventDefault();
  });
</script>

<script>
  import { gsap, ScrollTrigger } from "../../lib/gsap";

  const tl = gsap.timeline({
    scrollTrigger: { trigger: "#exemples", start: "top 70%" },
  });

  tl.from("#exemples h2", {
    y: 30,
    autoAlpha: 0,
    duration: 0.7,
    ease: "power2.out",
  }).from(
    "#exemples-track > div:not([aria-hidden])",
    {
      x: 40,
      autoAlpha: 0,
      duration: 0.6,
      ease: "power2.out",
      stagger: 0.1,
    },
    "-=0.3",
  );
</script>

<script>
  const track = document.getElementById("exemples-track");
  const prev = document.getElementById("exemples-prev");
  const next = document.getElementById("exemples-next");

  function slideWidth(): number {
    const slide = track?.querySelector<HTMLElement>(":scope > div:not([aria-hidden])");
    if (!slide || !track) return 0;
    const gap = parseFloat(getComputedStyle(track).gap) || 20;
    return slide.offsetWidth + gap;
  }

  prev?.addEventListener("click", () => {
    track?.scrollBy({ left: -slideWidth(), behavior: "smooth" });
  });

  next?.addEventListener("click", () => {
    track?.scrollBy({ left: slideWidth(), behavior: "smooth" });
  });
</script>
