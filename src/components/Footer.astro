      </section>

      <hr class="border-t border-gold/30" />

      <section>
        <h3 class="font-sans text-xs tracking-[0.2em] uppercase text-gold mb-4">
          <span class="text-gold/40">07.</span> Livraison
        </h3>
        <p>
