          ArtSoul — le monde<br />
          Justine — la voix
        </p>
      </section>
    </div>
  </div>
</div>

<script>
  // ── Ouverture des modals légaux ────────────────────────────────────────────

  const modals: Record<string, HTMLElement | null> = {
    mentions: document.getElementById("modal-mentions"),
    confidentialite: document.getElementById("modal-confidentialite"),
    cgv: document.getElementById("modal-cgv"),
  };

  let lastFocused: HTMLElement | null = null;

  function openModal(key: string) {
    const modal = modals[key];
    if (!modal) return;
    lastFocused = document.activeElement as HTMLElement;
    modal.classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    // Focus le bouton de fermeture
    const closeBtn = modal.querySelector<HTMLElement>("[data-close-modal]");
    closeBtn?.focus();
  }

  function closeModal(modal: HTMLElement) {
    modal.classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    lastFocused?.focus();
  }

  // Boutons d'ouverture (dans le footer)
  document.querySelectorAll<HTMLElement>("[data-legal]").forEach((btn) => {
    btn.addEventListener("click", () => openModal(btn.dataset.legal!));
  });

  // Boutons de fermeture (dans chaque modal)
  document
    .querySelectorAll<HTMLElement>("[data-close-modal]")
    .forEach((btn) => {
      const modal = btn.closest<HTMLElement>("[role='dialog']");
      if (!modal) return;
      btn.addEventListener("click", () => closeModal(modal));
    });

  // Fermeture via Escape
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    Object.values(modals).forEach((modal) => {
      if (modal && !modal.classList.contains("hidden")) closeModal(modal);
    });
  });

  // Fermeture au clic sur le fond (hors contenu)
  Object.values(modals).forEach((modal) => {
    if (!modal) return;
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal(modal);
    });
  });
</script>
