---
// Footer — copyright, réseaux sociaux, liens légaux (modals)
import MentionsModal from "./modals/MentionsModal.astro";
import ConfidentialiteModal from "./modals/ConfidentialiteModal.astro";
import CgvModal from "./modals/CgvModal.astro";

const year = new Date().getFullYear();
---

<!-- ============================================================
     FOOTER
     ============================================================ -->
<footer class="bg-ink border-t border-paper/10 py-12 px-6">
  <div
    class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left"
  >
    <!-- Nom + copyright -->
    <div>
      <p class="font-display text-paper text-lg mb-1">Justine</p>
      <p class="font-sans text-xs text-paper/25">
        © {year} Art Soul. Tous droits réservés.
      </p>
    </div>

    <!-- Réseaux sociaux -->
    <div class="flex items-center gap-6">
      <!-- Instagram -->
      <a
        href="https://www.instagram.com/artsoul_justine/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-paper/40 hover:text-paper transition-colors duration-300"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"
          ></circle>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/justine-douinot-artsoulset/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-paper/40 hover:text-paper transition-colors duration-300"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
    </div>

    <!-- Liens légaux — ouvrent un modal (cf. composants <...Modal /> en bas) -->
    <div class="flex flex-wrap justify-center lg:justify-end gap-x-6 gap-y-2">
      <button
        data-legal="mentions"
        class="font-sans text-xs text-paper/25 hover:text-paper/60 transition-colors duration-300 cursor-pointer bg-transparent border-none"
      >
        Mentions légales
      </button>
      <button
        data-legal="confidentialite"
        class="font-sans text-xs text-paper/25 hover:text-paper/60 transition-colors duration-300 cursor-pointer bg-transparent border-none"
      >
        Politique de confidentialité
      </button>
      <button
        data-legal="cgv"
        class="font-sans text-xs text-paper/25 hover:text-paper/60 transition-colors duration-300 cursor-pointer bg-transparent border-none"
      >
        Conditions Générales de Vente
      </button>
    </div>
  </div>
</footer>

<!-- ============================================================
     MODALS LÉGAUX
     Chaque bouton [data-legal="X"] ouvre le modal #modal-X correspondant.
     ============================================================ -->
<MentionsModal />
<ConfidentialiteModal />
<CgvModal />

<script>
  // ── Gestion des modals légaux ──────────────────────────────────────────────
  // Découverte auto via [data-legal-modal] : ajouter un nouveau modal légal
  // ne nécessite aucune modification de ce script.

  const legalModals = document.querySelectorAll<HTMLElement>(
    "[data-legal-modal]",
  );
  let lastFocused: HTMLElement | null = null;

  function openModal(modal: HTMLElement) {
    lastFocused = document.activeElement as HTMLElement;
    modal.classList.remove("hidden");
    document.body.classList.add("overflow-hidden");
    modal.querySelector<HTMLElement>("[data-close-modal]")?.focus();
  }

  function closeModal(modal: HTMLElement) {
    modal.classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
    lastFocused?.focus();
  }

  // Boutons d'ouverture : data-legal="cgv" → ouvre #modal-cgv
  document.querySelectorAll<HTMLElement>("[data-legal]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const modal = document.getElementById(`modal-${btn.dataset.legal}`);
      if (modal) openModal(modal);
    });
  });

  // Pour chaque modal légal : fermeture via × et clic sur le fond
  legalModals.forEach((modal) => {
    modal
      .querySelector<HTMLElement>("[data-close-modal]")
      ?.addEventListener("click", () => closeModal(modal));

    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal(modal);
    });
  });

  // Escape ferme le modal légal ouvert (s'il y en a un)
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    legalModals.forEach((modal) => {
      if (!modal.classList.contains("hidden")) closeModal(modal);
    });
  });
</script>
